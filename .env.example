# DeepTrace Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# ── API ──────────────────────────────────────────────────────────────────────
API_KEYS=dev-key-123,your-production-key-here
DEBUG=false

# ── Model ────────────────────────────────────────────────────────────────────
# Local checkpoint (development):
MODEL_URI=checkpoints/calibrated_model.pt
# MLflow registry (production):
# MODEL_URI=models:/DeepTrace/Production
MODEL_DEVICE=cpu
# MODEL_DEVICE=cuda   # uncomment for GPU inference

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Storage (S3 for XAI artifacts) ───────────────────────────────────────────
S3_BUCKET=deeptrace-artifacts
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Integrations ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # for natural-language XAI explanations
SLACK_WEBHOOK_URL=           # for drift alerts

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_API_KEY=dev-key-123

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=deeptrace

# ── Data (for DVC remote) ─────────────────────────────────────────────────────
DVC_REMOTE_URL=s3://your-bucket/dvc-store
