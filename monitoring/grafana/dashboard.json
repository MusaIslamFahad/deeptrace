{
  "__inputs": [],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Total Predictions (24h)",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "increase(deeptrace_http_requests_total{endpoint='/api/v1/predict',status='200'}[24h])",
        "legendFormat": "Predictions"
      }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Avg Inference Latency (ms)",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "histogram_quantile(0.50, rate(deeptrace_inference_latency_seconds_bucket[5m])) * 1000",
        "legendFormat": "p50 latency"
      }],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "type": "stat",
      "title": "p99 Inference Latency (ms)",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(deeptrace_inference_latency_seconds_bucket[5m])) * 1000",
        "legendFormat": "p99 latency"
      }],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Error Rate",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "rate(deeptrace_http_requests_total{status=~'5..'}[5m]) / rate(deeptrace_http_requests_total[5m])",
        "legendFormat": "Error rate"
      }],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Predictions by Source Class",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(deeptrace_predictions_total{predicted_class='stable_diffusion'}[5m])", "legendFormat": "Stable Diffusion" },
        { "expr": "rate(deeptrace_predictions_total{predicted_class='midjourney'}[5m])",       "legendFormat": "Midjourney" },
        { "expr": "rate(deeptrace_predictions_total{predicted_class='dalle3'}[5m])",           "legendFormat": "DALL-E 3" },
        { "expr": "rate(deeptrace_predictions_total{predicted_class='flux'}[5m])",             "legendFormat": "Flux" },
        { "expr": "rate(deeptrace_predictions_total{predicted_class='real'}[5m])",             "legendFormat": "Real" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "type": "timeseries",
      "title": "Request Latency Percentiles",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(deeptrace_inference_latency_seconds_bucket[5m]))*1000", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(deeptrace_inference_latency_seconds_bucket[5m]))*1000", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(deeptrace_inference_latency_seconds_bucket[5m]))*1000", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    }
  ],
  "schemaVersion": 38,
  "tags": ["deeptrace", "ml-monitoring"],
  "title": "DeepTrace — Production Dashboard",
  "version": 1
}
